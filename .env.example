# ===== AI / OCR engines — set at least one =====

# Engine default: "lighton" atau "gpt-4o"
DEFAULT_AI_ENGINE=lighton

# --- LightOn OCR (OpenAI-compatible endpoint) ---
# Cloud: https://api.lighton.ai/v1   atau endpoint vLLM lokal kamu
LIGHTON_API_KEY=
LIGHTON_BASE_URL=https://api.lighton.ai/v1
LIGHTON_MODEL=lighton-ocr

# --- OpenAI GPT-4o (vision) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ===== Gmail OAuth =====
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json

# ===== Google Sheets (opsional, --sheets) =====
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/sheets_service_account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Invoices

# ===== Output =====
CSV_OUTPUT_PATH=output/invoices.csv
EXCEL_OUTPUT_PATH=output/invoices.xlsx
